# terraform.tfvars.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it is in .gitignore.
# Sensitive values (db_password) can also be passed via environment variable:
#   export TF_VAR_db_password="your-password"

# ── Required ──────────────────────────────────────────────────────────────────

project_id = "your-gcp-project-id"    # gcloud projects list
region     = "us-central1"
zone       = "us-central1-a"

# ── Identity ──────────────────────────────────────────────────────────────────

environment = "demo"

# ── Compute ───────────────────────────────────────────────────────────────────

app_machine_type = "e2-medium"   # e2-small is cheaper; e2-medium handles real load
app_port         = 8080

# SSH — set to true and restrict source to your IP while debugging, then disable
enable_ssh      = false
ssh_source_cidr = "YOUR_IP/32"  # e.g. 203.0.113.42/32

# ── Database ──────────────────────────────────────────────────────────────────

db_tier     = "db-f1-micro"    # cheapest tier; db-g1-small if you need more headroom
db_name     = "shizen"
db_user     = "shizen_user"
db_password = "change-me-use-env-var-instead"  # prefer: export TF_VAR_db_password=...

# ── DNS (optional) ────────────────────────────────────────────────────────────

# domain_name = "demo.shizenai.tech"   # Uncomment to see DNS instructions in outputs
